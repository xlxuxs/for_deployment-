# Server
PORT=5000

# MongoDB
# Use your MongoDB Atlas connection string here.
# Make sure it includes your database name, for example:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.<id>.mongodb.net/communityinsight?retryWrites=true&w=majority&appName=Cluster0
MONGO_URI=mongodb+srv://abrahamadugna_db_user:IiiFxZcKgpOMpKx7@cluster0.ofh8gt9.mongodb.net/communityinsight?retryWrites=true&w=majority&appName=Cluster0

# JWT Secret
JWT_SECRET=your_super_secret_key_here

# Redis (required for rate limiting, sessions, caching)
REDIS_URL=redis://localhost:6379

# AI Service URL
AI_SERVICE_URL=https://ai-sevice.onrender.com

# Translation Space URL
TRANSLATE_SPACE_URL=https://abraham-ad77-ethio-translate.hf.space/translate

# Email OTP settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Internal API Key for AI service communication
INTERNAL_API_KEY=your-internal-api-key-here

# Frontend URL for password reset links
FRONTEND_URL=http://localhost:3000

# LibreTranslate (optional)
# LIBRE_TRANSLATE_URL=http://localhost:5000

# Auto retry settings for comments
AUTO_RETRY_ENABLED=true
AUTO_RETRY_INTERVAL_HOURS=6
AUTO_RETRY_AGE_DAYS=7
AUTO_RETRY_MAX_ATTEMPTS=2

# reCAPTCHA keys (get from Google)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# CORS allowed origins (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Disable CAPTCHA for local development (set to true to skip)
DISABLE_CAPTCHA=true